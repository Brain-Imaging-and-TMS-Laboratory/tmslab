<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
    <!-- Font-size accessibility toggle: preload class applied to
         <html> *before* body renders, so saved "large" / "xlarge"
         preferences don't flash the regular size on first paint.
         Main JS in /assets/js/font-toggle.js takes over after load,
         syncs body classes, and clears these preload classes. -->
    <script>
      (function () {
        try {
          var size = localStorage.getItem("tmslab-font-size");
          if (size === "large") {
            document.documentElement.classList.add("font-size-large-preload");
          } else if (size === "xlarge") {
            document.documentElement.classList.add("font-size-xlarge-preload");
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- News ticker — homepage only. Sits below the fixed navbar;
         the include itself also no-ops when _news/ is empty. -->
    {% if page.layout == 'about' %}
      {% include news_ticker.liquid %}
    {% endif %}

    <!-- Content -->
    <div class="container mt-5 layout-{{ page.layout }}" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- "Participate in a Study" modal. Triggers live inline on the
         Join Us and Research pages (and any other element with
         data-tmslab-open-modal="participate"). The site-wide floating
         button was removed — the inline triggers cover the use case
         without the persistent visual clutter. -->
    {% include participate_modal.liquid %}

    <!-- Font-size accessibility toggle — bottom-left floating pill.
         Sits opposite the Participate-modal triggers (which live on
         Join Us + Research via the bottom-right pattern) so the two
         floating UIs don't collide on any page.                     -->
    <div class="tmslab-font-toggle" role="group" aria-label="Adjust text size">
      <button type="button"
              class="tmslab-font-toggle-btn"
              data-font-size="regular"
              aria-label="Regular text size"
              aria-pressed="true">
        <span class="tmslab-font-toggle-a" style="font-size: 0.85em;">A</span>
      </button>
      <button type="button"
              class="tmslab-font-toggle-btn"
              data-font-size="large"
              aria-label="Large text size"
              aria-pressed="false">
        <span class="tmslab-font-toggle-a" style="font-size: 1em;">A</span>
      </button>
      <button type="button"
              class="tmslab-font-toggle-btn"
              data-font-size="xlarge"
              aria-label="Extra large text size"
              aria-pressed="false">
        <span class="tmslab-font-toggle-a" style="font-size: 1.2em;">A</span>
      </button>
    </div>
    <div id="tmslab-font-toggle-status" class="sr-only" aria-live="polite"></div>

    <script src="{{ '/assets/js/participate-modal.js' | relative_url }}" defer></script>
    <script src="{{ '/assets/js/font-toggle.js' | relative_url }}" defer></script>

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
